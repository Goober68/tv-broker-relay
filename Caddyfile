# Caddyfile — 3-service routing
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt.
#
# Routing:
#   /webhook/*  → relay:8001   (latency-critical webhook ingestion)
#   everything  → dashboard:8002 (API, SSE, frontend)

tvbrokerrelay.com {
    # Webhook traffic → relay service
    handle /webhook/* {
        reverse_proxy relay:8001
    }

    # Everything else → dashboard service
    handle {
        reverse_proxy dashboard:8002
    }

    # Security headers
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Access logs
    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}
