# Caddyfile
# Caddy automatically obtains and renews TLS certificates from Let's Encrypt.
# Replace yourdomain.com with your actual domain.
#
# Requirements:
#   - Domain DNS A record must point to this server's IP
#   - Ports 80 and 443 must be open in your firewall/security group

yourdomain.com {
    # Reverse proxy all requests to the FastAPI app
    reverse_proxy app:8000

    # Security headers
    header {
        # Prevent clickjacking
        X-Frame-Options "DENY"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # Enable HSTS (1 year)
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server identification
        -Server
    }

    # Rate limiting for auth endpoints (brute force protection)
    # Requires Caddy to be built with the rate_limit module, or use a WAF.
    # Uncomment if available:
    # @auth_routes path /auth/login /auth/register
    # rate_limit @auth_routes 10r/m

    # Access logs
    log {
        output file /var/log/caddy/access.log {
            roll_size 50mb
            roll_keep 5
        }
        format json
    }
}

# Redirect www → apex (optional)
# www.yourdomain.com {
#     redir https://yourdomain.com{uri} permanent
# }
