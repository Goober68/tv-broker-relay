# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=change_me_to_a_random_secret

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://relay:relay@localhost:5432/relay

# ── Risk Defaults ──────────────────────────────────────────────────────────────
MAX_POSITION_SIZE=100000
MAX_DAILY_LOSS=5000
DUPLICATE_WINDOW_SECONDS=10

# ── Oanda ──────────────────────────────────────────────────────────────────────
OANDA_API_KEY=
OANDA_ACCOUNT_ID=
# Live: https://api-fxtrade.oanda.com/v3
# Demo: https://api-fxpractice.oanda.com/v3
OANDA_BASE_URL=https://api-fxpractice.oanda.com/v3

# ── IBKR (Client Portal Gateway) ──────────────────────────────────────────────
IBKR_GATEWAY_URL=https://localhost:5000/v1/api
IBKR_ACCOUNT_ID=

# ── Tradovate ─────────────────────────────────────────────────────────────────
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_APP_VERSION=1.0
# Live: https://live.tradovateapi.com/v1
# Demo: https://demo.tradovateapi.com/v1
TRADOVATE_BASE_URL=https://demo.tradovateapi.com/v1

# ── E*Trade ───────────────────────────────────────────────────────────────────
ETRADE_CONSUMER_KEY=
ETRADE_CONSUMER_SECRET=
ETRADE_OAUTH_TOKEN=
ETRADE_OAUTH_TOKEN_SECRET=
ETRADE_ACCOUNT_ID=
# Live: https://api.etrade.com
# Sandbox: https://apisb.etrade.com
ETRADE_BASE_URL=https://apisb.etrade.com

# ── JWT ───────────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Credential Encryption ─────────────────────────────────────────────────────
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key==

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://yourdomain.com/billing/success
STRIPE_CANCEL_URL=https://yourdomain.com/billing/cancel

# ── Stripe Webhook Events ──────────────────────────────────────────────────────
# Register these events in the Stripe dashboard (or via CLI during development):
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
#   invoice.paid
#   invoice.payment_failed
#
# For local development, use the Stripe CLI:
#   stripe listen --forward-to localhost:8000/billing/webhook
#   (this sets STRIPE_WEBHOOK_SECRET automatically in the CLI output)

# ── Background Tasks ──────────────────────────────────────────────────────────
FILL_POLL_INTERVAL_SECONDS=30
PNL_POLL_INTERVAL_SECONDS=60
RECONCILE_INTERVAL_SECONDS=300
IBKR_KEEPALIVE_INTERVAL_SECONDS=55
DAILY_SUMMARY_HOUR_UTC=7

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email entirely
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USERNAME=your@email.com
SMTP_PASSWORD=yourpassword
SMTP_FROM=noreply@yourdomain.com
SMTP_USE_TLS=true
EMAIL_ENABLED=true

# ── Rithmic R|Web API ──────────────────────────────────────────────────────────
# Request API access at: https://www.rithmic.com/rithmic-web-api
RITHMIC_USERNAME=
RITHMIC_PASSWORD=
RITHMIC_APP_KEY=
# Sim:  "Rithmic Paper Trading"
# Live: "Rithmic 01" (or as assigned)
RITHMIC_SYSTEM_NAME=Rithmic Paper Trading
# Sim:  https://paper-rithmic-rapi.rithmic.com
# Live: https://rithmic-rapi.rithmic.com  (confirm with Rithmic)
RITHMIC_BASE_URL=https://paper-rithmic-rapi.rithmic.com

# ── TradeStation ───────────────────────────────────────────────────────────────
# Register at https://developer.tradestation.com
TRADESTATION_CLIENT_ID=
TRADESTATION_CLIENT_SECRET=
TRADESTATION_REFRESH_TOKEN=
TRADESTATION_ACCOUNT_ID=
# Live: https://api.tradestation.com  Sim: https://sim-api.tradestation.com
TRADESTATION_BASE_URL=https://sim-api.tradestation.com

# ── Alpaca ─────────────────────────────────────────────────────────────────────
# Register at https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Live: https://api.alpaca.markets  Paper: https://paper-api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Tastytrade ─────────────────────────────────────────────────────────────────
# Sandbox: https://api.cert.tastytrade.com
TASTYTRADE_USERNAME=
TASTYTRADE_PASSWORD=
TASTYTRADE_ACCOUNT_ID=
TASTYTRADE_BASE_URL=https://api.tastytrade.com
