# Staging environment — copy to .env.staging and fill in
# Use demo/sandbox broker URLs and separate secrets from production

# ── Security ──────────────────────────────────────────────────────────────────
WEBHOOK_SECRET=staging-change-me

# ── Database (overridden by docker-compose.staging.yml) ──────────────────────
DATABASE_URL=postgresql+asyncpg://relay:relay@db:5432/relay_staging
POSTGRES_PASSWORD=staging-password-change-me

# ── JWT (use different secrets from production!) ──────────────────────────────
JWT_SECRET=staging-jwt-secret-change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Credential Encryption (use different key from production!) ────────────────
CREDENTIAL_ENCRYPTION_KEY=generate-a-separate-fernet-key-for-staging==

# ── Risk Defaults ─────────────────────────────────────────────────────────────
MAX_POSITION_SIZE=10000
MAX_DAILY_LOSS=1000
DUPLICATE_WINDOW_SECONDS=10

# ── Brokers — use demo/sandbox URLs ──────────────────────────────────────────
OANDA_BASE_URL=https://api-fxpractice.oanda.com/v3
TRADOVATE_BASE_URL=https://demo.tradovateapi.com/v1
ALPACA_BASE_URL=https://paper-api.alpaca.markets
TRADESTATION_BASE_URL=https://sim-api.tradestation.com

# ── Stripe (test mode) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=https://staging.tvbrokerrelay.com/billing/success
STRIPE_CANCEL_URL=https://staging.tvbrokerrelay.com/billing/cancel

# ── Email (disable or use test SMTP) ─────────────────────────────────────────
EMAIL_ENABLED=false
